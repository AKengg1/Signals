# ── Server ─────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Auth ──────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=8

# ── Database ──────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password